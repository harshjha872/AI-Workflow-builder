{
  "name": "ai-workflow-builder-backend",
  "version": "1.0.0",
  "description": "Backend API for the Mini AI Workflow Builder",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "openai": "^4.80.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "vm2": "^3.9.19",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}